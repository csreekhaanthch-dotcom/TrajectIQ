# ============================================
# TrajectIQ Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string (required for production)
# Get a free database at https://neon.tech
DATABASE_URL="postgresql://user:password@host:5432/trajectiq?sslmode=require"

# ============================================
# Authentication Configuration
# ============================================
# JWT secret key - generate a secure random string for production
# You can use: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# JWT token expiration time
JWT_EXPIRES_IN="7d"

# ============================================
# Encryption Configuration
# ============================================
# AES-256 encryption key (must be exactly 32 bytes)
# You can use: openssl rand -base64 32
ENCRYPTION_KEY="your-encryption-key-32-bytes-!"

# ============================================
# Application Configuration
# ============================================
# Application name displayed in UI
NEXT_PUBLIC_APP_NAME="TrajectIQ"

# Application URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment (development, production, test)
NODE_ENV="development"

# ============================================
# Optional: Email Connector Configuration
# ============================================
# Gmail OAuth (if using Gmail connector)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI=""

# Microsoft OAuth (if using Outlook connector)
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""
# MICROSOFT_REDIRECT_URI=""

# ============================================
# Optional: ATS Integration Configuration
# ============================================
# Greenhouse API Key
# GREENHOUSE_API_KEY=""

# Lever API Key
# LEVER_API_KEY=""

# ============================================
# Optional: AI/ML Configuration
# ============================================
# If using external AI services for enhanced parsing
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
