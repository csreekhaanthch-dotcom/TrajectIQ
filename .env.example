# TrajectIQ Environment Configuration
# =====================================
# Copy this file to .env for local development
# Set these variables in Vercel Dashboard for production

# Database (PostgreSQL for Vercel/Production)
# Get a free PostgreSQL database from:
# - Neon: https://neon.tech
# - Supabase: https://supabase.com
# - Vercel Postgres: https://vercel.com/storage/postgres
# - Railway: https://railway.app
DATABASE_URL="postgresql://user:password@host:5432/trajectiq?sslmode=require"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Encryption (32 bytes for AES-256)
ENCRYPTION_KEY="your-encryption-key-32-bytes-!"

# Application
NEXT_PUBLIC_APP_NAME="TrajectIQ"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NODE_ENV="production"

# Email Configuration (for notifications)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
