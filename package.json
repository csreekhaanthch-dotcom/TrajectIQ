{
  "name": "trajectiq",
  "version": "2.0.0",
  "description": "Email-Driven Hiring Intelligence SaaS Platform with Advanced AI Pipeline",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:ai": "cd backend && python -m uvicorn main:app --reload --port 8001",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ai\"",
    "build": "prisma generate && prisma db push --accept-data-loss && next build",
    "start": "next start",
    "start:ai": "cd backend && python -m uvicorn main:app --port 8001",
    "lint": "next lint",
    "test": "jest --config jest.config.json",
    "test:watch": "jest --config jest.config.json --watch",
    "test:coverage": "jest --config jest.config.json --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "bun run prisma/seed.ts",
    "ai:install": "cd backend && pip install -r requirements.txt",
    "ai:download-models": "python -c \"import spacy; spacy.download('en_core_web_lg')\""
  },
  "dependencies": {
    "@googleapis/gmail": "^16.1.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/imap": "^0.8.43",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "framer-motion": "^12.36.0",
    "imap": "^0.8.19",
    "imapflow": "^1.2.13",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "mammoth": "^1.12.0",
    "next": "^15.1.6",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^10.0.0",
    "z-ai-web-dev-sdk": "latest",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "jest": "^29.7.0",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
